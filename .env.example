# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Dev access (remove for public deploy)
DEV_ACCESS_PIN=your_pin
DEV_USER_ID=your_user_id

# Local multi-profile dev access
# Guarda esto en .env.development.local si usas `vercel env pull .env.local`,
# para que Vercel no te sobrescriba los PINs locales.
DEV_ACCESS_PIN_LUIS=your_pin_for_luis
DEV_USER_ID_LUIS=your_user_id_for_luis
DEV_ACCESS_PIN_PAREJA=your_pin_for_pareja
DEV_USER_ID_PAREJA=your_user_id_for_pareja

# AI providers for ideas / motor-ai
IDEAS_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-sonnet-4-6
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
